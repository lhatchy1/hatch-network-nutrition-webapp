# Firebase web config — fill these in and copy to .env (or .env.local) to
# enable sign-in and cloud sync. Without these values the app runs in
# offline-only mode using localStorage.
#
# Get them from: Firebase Console → Project settings → General → "Your apps"
# (Web app) → "SDK setup and configuration" → Config.
#
# Note: the apiKey is *not* a secret — Firebase enforces access via security
# rules + the user-actions sign-up lockdown. These are baked into the bundle.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Cloudflare Worker that proxies the Migros product-display API (CORS).
# Leave blank to fall back to corsproxy.io — fine for local dev, but
# corsproxy.io's free tier blocks production usage from food.hatchnetwork.ch.
# Setup instructions: infra/README.md.
# The URL must end with "?url=" so the app can append the encoded target.
VITE_MIGROS_PROXY=
